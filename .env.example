# HumaneProxy environment variables.
# Rename this file to .env and fill in your values.

# ─── Upstream LLM (required for reverse proxy mode only) ──────────
LLM_API_KEY=
LLM_API_URL=

# ─── Stage 3 LLM Provider (optional) ──────────────────────────────
# Option A: Groq API key for LlamaGuard (free tier, very fast)
# GROQ_API_KEY=gsk_...
# Option B: OpenAI API key for OpenAI Moderation API
# OPENAI_API_KEY=sk-...

# ─── Admin API ─────────────────────────────────────────────────────
# Required if exposing /admin endpoints
# HUMANE_PROXY_ADMIN_KEY=your-secret-token

